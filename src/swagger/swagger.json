    "/startups/": {
      "get": {
        "tags": [
          "Startups Endpoints"
        ],
        "summary": "Get all startups",
        "description": "Pull all startups from the database. ",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Startups Endpoints"
        ],
        "summary": "Create a new startup",
        "description": "Insert new startup in the database. ",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "New startup data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "KongoTech"
                },
                "description": {
                  "type": "string",
                  "example": "FinTech startup providing digital payment solutions"
                },
                "industry": {
                  "type": "string",
                  "example": "FinTech"
                },
                "founders": {
                  "type": "array",
                  "example": [
                    "Baron Mobs"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "foundedYear": {
                  "type": "number",
                  "example": 2022
                },
                "location": {
                  "type": "object",
                  "properties": {
                    "ward": {
                      "type": "string",
                      "example": "Ngiri-Ngiri"
                    },
                    "stake": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "commune": {
                      "type": "string",
                      "example": "Ngiri-Ngiri"
                    },
                    "city": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "province": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "country": {
                      "type": "string",
                      "example": "DR Congo"
                    }
                  }
                },
                "phone": {
                  "type": "string",
                  "example": "+243810000000"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
